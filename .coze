[project]
requires = ["python-3"]

[dev]
build = ["pip", "install", "-q", "openpyxl", "pyyaml", "flask", "requests"]
run = ["python", "scripts/app_server.py", "--host", "0.0.0.0", "--port", "5000"]

[deploy]
build = ["pip", "install", "-q", "openpyxl", "pyyaml", "flask", "requests"]
run = ["python", "scripts/app_server.py", "--host", "0.0.0.0", "--port", "5000"]
